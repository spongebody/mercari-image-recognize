OPENROUTER_API_KEY=
VISION_MODEL=openai/gpt-4o
CATEGORY_MODEL=openai/gpt-4o
PRODUCT_DATA_MODEL=google/gemini-2.5-flash
REASONING_ENABLED=
REASONING_EFFORT=medium
REASONING_MAX_TOKENS=
REASONING_SUMMARY=
IMAGE_COMPRESSION_THRESHOLD_MB=1
LOG_REQUESTS=true
# Logs viewer auth (empty disables /logs and /config)
LOGS_PASSWORD=

# Observability retention (days OR bytes — whichever hits first)
LOG_RETENTION_DAYS=7
LOG_MAX_TOTAL_BYTES=5368709120
LOG_PRUNE_INTERVAL_MINUTES=60
LOG_RESPONSE_MAX_BYTES=2097152
ENABLE_DEBUG=true
REQUEST_TIMEOUT=60
MODEL_CALL_MAX_RETRIES=3
MODEL_CALL_TOTAL_BUDGET_SECONDS=120
VISION_FALLBACK_MODELS=openai/gpt-4o-mini,openai/gpt-4o,google/gemini-3-flash-preview
CATEGORY_FALLBACK_MODELS=openai/gpt-4o-mini,openai/gpt-4o,google/gemini-2.5-flash
# Fallback chain used for both the primary product-data model and the
# explicit PRODUCT_DATA_FALLBACK_MODEL when their respective request fails.
PRODUCT_DATA_FALLBACK_MODELS=openai/gpt-4o,google/gemini-3-flash-preview

# Showcase image generation (POST /api/v1/showcase/generate)
SHOWCASE_MODEL=google/gemini-3.1-flash-image-preview
SHOWCASE_STORAGE_ROOT=storage
SHOWCASE_RETAIN_INPUT_FILES=false
SHOWCASE_RETAIN_OUTPUT_FILES=false
SHOWCASE_REQUEST_TIMEOUT=120
SHOWCASE_MAX_RETRIES=3
# Comma-separated list of fallback image-generation models tried in order
# after every retry against SHOWCASE_MODEL is exhausted. Leave empty to disable.
SHOWCASE_FALLBACK_MODELS=openai/gpt-5.4-image-2,google/gemini-3-pro-image-preview
SHOWCASE_TIMEZONE=Asia/Shanghai
